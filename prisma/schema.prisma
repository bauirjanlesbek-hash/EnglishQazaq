// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Users & Auth ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  bio           String?

  // Profile stats
  xp            Int       @default(0)
  level         Int       @default(1)
  dailyStreak   Int       @default(0)
  longestStreak Int       @default(0)
  lastActivityAt DateTime?

  // Subscription
  subscriptionPlan String   @default("free") // free, premium, vip
  subscriptionEndsAt DateTime?
  stripeCustomerId String?

  // Relations
  userProgress    UserProgress[]
  achievements    UserAchievement[]
  certificates    Certificate[]
  submissions     UserSubmission[]
  answers         QuizAnswer[]
  leaderboardEntry Leaderboard?
  payments        Payment[]
  oauthAccounts   OAuthAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([subscriptionPlan])
}

model OAuthAccount {
  id            String  @id @default(cuid())
  userId        String
  provider      String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ==================== Courses & Learning ====================

model Course {
  id          String    @id @default(cuid())
  title       String
  description String
  slug        String    @unique
  level       String    // beginner, intermediate, advanced
  image       String?
  order       Int       @default(0)
  isPublished Boolean   @default(false)

  modules     Module[]
  userProgress UserProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([isPublished])
}

model Module {
  id        String  @id @default(cuid())
  courseId  String
  title     String
  description String
  order     Int     @default(0)

  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String    @id @default(cuid())
  moduleId    String
  title       String
  content     String    // Rich text content
  videoUrl    String?
  order       Int       @default(0)
  estimatedTime Int    @default(10) // minutes

  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  exercises   Exercise[]
  quizzes     Quiz[]
  userProgress LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
}

// ==================== Vocabulary ====================

model Vocabulary {
  id          String    @id @default(cuid())
  english     String
  kazakh      String
  pronunciation String
  partOfSpeech String   // noun, verb, adjective, etc.
  example     String?
  audioUrl    String?
  imageUrl    String?
  level       String    // beginner, intermediate, advanced
  category    String    // common, business, academic, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([level])
  @@index([category])
}

// ==================== Exercises ====================

model Exercise {
  id          String    @id @default(cuid())
  lessonId    String
  type        String    // multiple_choice, fill_blanks, translation, speaking, listening, drag_drop
  question    String
  content     String    // JSON format for complex exercises
  correctAnswer String?
  explanation String?
  order       Int       @default(0)

  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userAnswers UserAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
  @@index([type])
}

model UserAnswer {
  id          String    @id @default(cuid())
  exerciseId  String
  userId      String
  answer      String
  isCorrect   Boolean
  xpEarned    Int       @default(0)

  exercise    Exercise  @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([exerciseId])
  @@index([userId])
}

// ==================== Quizzes ====================

model Quiz {
  id          String    @id @default(cuid())
  lessonId    String
  title       String
  description String?
  questions   QuizQuestion[]
  minScore    Int       @default(70) // percentage

  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lessonId])
}

model QuizQuestion {
  id          String    @id @default(cuid())
  quizId      String
  question    String
  options     String    // JSON array of options
  correctAnswer String
  explanation String?
  order       Int       @default(0)

  quiz        Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     QuizAnswer[]

  @@index([quizId])
}

model QuizAnswer {
  id          String    @id @default(cuid())
  quizId      String
  questionId  String
  userId      String
  selectedAnswer String
  isCorrect   Boolean

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([questionId])
}

// ==================== User Progress ====================

model UserProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  completedLessons Int @default(0)
  totalLessons Int
  xpEarned    Int       @default(0)
  completionPercentage Float @default(0)
  completedAt DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userProgressId String
  lessonId    String
  isCompleted Boolean   @default(false)
  xpEarned    Int       @default(0)
  completedAt DateTime?

  userProgress UserProgress @relation(fields: [userProgressId], references: [id], onDelete: Cascade)
  lesson       Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userProgressId, lessonId])
  @@index([userProgressId])
  @@index([lessonId])
}

// ==================== Gamification ====================

model Achievement {
  id          String    @id @default(cuid())
  title       String    @unique
  description String
  icon        String
  requirement String    // JSON format
  xpReward    Int       @default(0)

  users       UserAchievement[]

  createdAt DateTime @default(now())
}

model UserAchievement {
  id              String    @id @default(cuid())
  userId          String
  achievementId   String
  unlockedAt      DateTime  @default(now())

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement     Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
}

model Leaderboard {
  id          String    @id @default(cuid())
  userId      String    @unique
  rank        Int
  xpTotal     Int       @default(0)
  level       Int       @default(1)
  lastUpdated DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([rank])
  @@index([xpTotal])
}

// ==================== Certificates ====================

model Certificate {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  certificateNumber String @unique
  qrCode      String
  issuedAt    DateTime  @default(now())
  expiresAt   DateTime?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([certificateNumber])
}

// ==================== Submissions ====================

model UserSubmission {
  id          String    @id @default(cuid())
  userId      String
  type        String    // essay, speaking, listening
  content     String    // Text or URL
  audioUrl    String?
  grade       Int?      // 0-100
  feedback    String?
  status      String    @default("pending") // pending, reviewed, approved

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ==================== Payments ====================

model Payment {
  id          String    @id @default(cuid())
  userId      String
  amount      Float
  currency    String    @default("USD")
  status      String    @default("pending") // pending, completed, failed
  plan        String    // premium, vip
  stripePaymentId String?
  receiptUrl  String?

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ==================== Challenges ====================

model DailyChallenge {
  id          String    @id @default(cuid())
  date        DateTime  @unique
  title       String
  description String
  xpReward    Int       @default(50)
  exerciseId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserChallenge {
  id          String    @id @default(cuid())
  userId      String
  challengeId String
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}
